module UnifiedTests exposing (tests)

import Expect exposing (Expectation)
import Test exposing (Test, describe, test)

import UnifiedDiff exposing (unifiedDiff)


text1 = """
This is line 1.
This is line 2.
This is line 3.
This is line 4.
This is line 5.
"""

changeLine1 = """
Changed
This is line 2.
This is line 3.
This is line 4.
This is line 5.
"""

changeLine3 = """
This is line 1.
This is line 2.
Changed
This is line 4.
This is line 5.
"""

changeLine5 = """
This is line 1.
This is line 2.
This is line 3.
This is line 4.
Changed
"""

removeLine1 = """
This is line 2.
This is line 3.
This is line 4.
This is line 5.
"""

removeLine3 = """
This is line 1.
This is line 2.
This is line 4.
This is line 5.
"""

removeLine5 = """
This is line 1.
This is line 2.
This is line 3.
This is line 4.
"""

tests : Test
tests =
    describe "UnifiedDiff"
        [ test "empty vs empty" <| \{} ->
            unifiedDiff "" ""
                |> Expect.equal ""

        , test "same vs same" <| \{} ->
            unifiedDiff text1 text1
                |> Expect.equal ""

        , test "change line 1" <| \{} ->
            unifiedDiff text1 changeLine1
                |> Expect.equal """
@@ -1,4 +1,4 @@
-This is line 1.
+Changed
 This is line 2.
 This is line 3.
 This is line 4.
"""

        , test "change line 3" <| \{} ->
            unifiedDiff text1 changeLine3
                |> Expect.equal """
@@ -1,5 +1,5 @@
 This is line 1.
 This is line 2.
-This is line 3.
+Changed
 This is line 4.
 This is line 5.
"""

        , test "change line 5" <| \{} ->
            unifiedDiff text1 changeLine5
                |> Expect.equal """
@@ -2,4 +2,4 @@
 This is line 2.
 This is line 3.
 This is line 4.
-This is line 5.
+Changed
"""

        , test "remove line 1" <| \{} ->
            unifiedDiff text1 removeLine1
                |> Expect.equal """
@@ -1,4 +1,3 @@
-This is line 1.
 This is line 2.
 This is line 3.
 This is line 4.
"""

        , test "remove line 3" <| \{} ->
            unifiedDiff text1 removeLine3
                |> Expect.equal """
@@ -1,5 +1,4 @@
 This is line 1.
 This is line 2.
-This is line 3.
 This is line 4.
 This is line 5.
"""

        , test "remove line 5" <| \{} ->
            unifiedDiff text1 removeLine5
                |> Expect.equal """
@@ -2,4 +2,3 @@
 This is line 2.
 This is line 3.
 This is line 4.
-This is line 5.
"""
        ]
